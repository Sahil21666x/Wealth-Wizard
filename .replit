modules = ["nodejs-20", "web"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Start Backend"

[[workflows.workflow]]
name = "Start Backend"
author = 44351242
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Backend && npm install && npm start"

[[workflows.workflow]]
name = "Start Frontend"
author = 44351242
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Frontend && npm install && npm run dev"

[[workflows.workflow]]
name = "Start Frontend Dev"
author = 44351242
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd Frontend && npm install && npm run dev"

[[ports]]
localPort = 5000
externalPort = 80
